<?xml version="1.0" encoding="utf-8"?>
<!-- Equivalent to light-template: ContentContainer.tsx
     Usage: <include layout="@layout/component_content_container" />
     IDs: content_header (include), content_scroll, content_inner,
          scroll_indicator_track, scroll_indicator_thumb
     - Toggle content_header visibility as needed.
     - Attach a scroll listener to content_scroll to animate scroll_indicator_thumb. -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/content_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/navbarBackground">

    <!-- Header (set visibility="gone" if no title needed) -->
    <include
        layout="@layout/component_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone" />

    <!-- Scroll area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ScrollView
            android:id="@+id/content_scroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="never"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/content_inner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="37dp"
                android:paddingEnd="46dp"
                android:paddingBottom="20dp">
                <!-- Page content goes here -->
            </LinearLayout>

        </ScrollView>

        <!-- Scroll indicator track (1dp wide, positioned to the right) -->
        <View
            android:id="@+id/scroll_indicator_track"
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_gravity="end"
            android:layout_marginEnd="12dp"
            android:background="@color/navbarIconActive"
            android:visibility="gone" />

        <!-- Scroll indicator thumb (5dp wide, positioned via code) -->
        <View
            android:id="@+id/scroll_indicator_thumb"
            android:layout_width="5dp"
            android:layout_height="40dp"
            android:layout_gravity="end"
            android:layout_marginEnd="10dp"
            android:background="@color/navbarIconActive"
            android:visibility="gone" />

    </FrameLayout>

</LinearLayout>
