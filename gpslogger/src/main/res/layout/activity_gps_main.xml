<?xml version="1.0" encoding="utf-8"?>

<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">


    <FrameLayout
        android:id="@+id/supercontainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent" >
        <FrameLayout
            android:id="@+id/container"
            android:layout_width="match_parent"
            android:layout_height="match_parent" >
        </FrameLayout>
        <LinearLayout
            android:id="@+id/bottomNavbar"
            android:layout_gravity="bottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/navbarBackground"
            android:paddingTop="11dp"
            android:paddingBottom="11dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <!-- GPS status indicator -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1">

                <ImageView
                    android:id="@+id/notification_bulb"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/circle_none"
                    android:contentDescription="GPS fix status" />

                <ProgressBar
                    android:id="@+id/progressBarGpsFix"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:indeterminateOnly="true"
                    android:visibility="invisible" />

            </FrameLayout>

            <ImageView
                android:id="@+id/navAnnotate"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:src="@drawable/annotate2"
                android:contentDescription="@string/menu_annotate"
                android:scaleType="center" />

            <ImageView
                android:id="@+id/navOnePoint"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:src="@drawable/singlepoint"
                android:contentDescription="@string/menu_onepoint"
                android:scaleType="center" />

            <ImageView
                android:id="@+id/navUpload"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:src="@drawable/upload"
                android:contentDescription="@string/menu_upload"
                android:scaleType="center" />

            <ImageView
                android:id="@+id/navShare"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:src="@drawable/share"
                android:contentDescription="@string/menu_share"
                android:scaleType="center" />

            <ImageView
                android:id="@+id/navViewSwitcher"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:src="@drawable/ic_view_switcher"
                android:contentDescription="Switch view"
                android:scaleType="center" />

            <ImageView
                android:id="@+id/navSettings"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:src="@drawable/settings"
                android:contentDescription="Settings"
                android:scaleType="center" />

        </LinearLayout>
    </FrameLayout>


</androidx.drawerlayout.widget.DrawerLayout>
