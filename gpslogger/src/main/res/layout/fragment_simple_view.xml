<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/navbarBackground"
    android:overScrollMode="never"
    android:scrollbars="none">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:paddingStart="37dp"
    android:paddingEnd="37dp"
    android:paddingTop="32dp"
    android:paddingBottom="16dp">

    <!-- Latitude -->
    <TextView
        android:id="@+id/simple_lat_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/navbarIconActive"
        android:textSize="48sp"
        android:maxLines="1"
        android:autoSizeTextType="uniform"
        android:autoSizeMinTextSize="12sp"
        android:autoSizeMaxTextSize="48sp"
        android:gravity="center"
        android:textIsSelectable="true" />

    <!-- Longitude -->
    <TextView
        android:id="@+id/simple_lon_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/navbarIconActive"
        android:textSize="48sp"
        android:maxLines="1"
        android:autoSizeTextType="uniform"
        android:autoSizeMinTextSize="12sp"
        android:autoSizeMaxTextSize="48sp"
        android:gravity="center"
        android:textIsSelectable="true" />

    <!-- Play/Pause button -->
    <ImageView
        android:id="@+id/btnActionProcess"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="24dp"
        android:src="@drawable/ic_play"
        android:contentDescription="Start/Stop logging"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true" />

    <!-- Stats grid -->
    <GridLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:columnCount="4"
        android:rowCount="4"
        android:useDefaultMargins="true">

        <ImageView android:id="@+id/simpleview_imgSatelliteCount"
            android:layout_width="24dp" android:layout_height="24dp"
            android:layout_row="0" android:layout_column="0"
            android:layout_gravity="center"
            android:src="@drawable/satellite_count"
            android:contentDescription="@string/txt_satellites" />
        <TextView android:id="@+id/simpleview_txtSatelliteCount"
            android:layout_width="80dp" android:layout_height="wrap_content"
            android:layout_row="0" android:layout_column="1"
            android:layout_gravity="center_vertical"
            android:textColor="@color/navbarIconActive" android:textIsSelectable="true" />

        <ImageView android:id="@+id/simpleview_imgAccuracy"
            android:layout_width="24dp" android:layout_height="24dp"
            android:layout_row="0" android:layout_column="2"
            android:layout_gravity="center"
            android:src="@drawable/accuracy"
            android:contentDescription="@string/txt_accuracy" />
        <TextView android:id="@+id/simpleview_txtAccuracy"
            android:layout_width="80dp" android:layout_height="wrap_content"
            android:layout_row="0" android:layout_column="3"
            android:layout_gravity="center_vertical"
            android:textColor="@color/navbarIconActive" android:textIsSelectable="true" />

        <ImageView android:id="@+id/simpleview_imgAltitude"
            android:layout_width="24dp" android:layout_height="24dp"
            android:layout_row="1" android:layout_column="0"
            android:layout_gravity="center"
            android:src="@drawable/altitude"
            android:contentDescription="@string/txt_altitude" />
        <TextView android:id="@+id/simpleview_txtAltitude"
            android:layout_width="80dp" android:layout_height="wrap_content"
            android:layout_row="1" android:layout_column="1"
            android:layout_gravity="center_vertical"
            android:textColor="@color/navbarIconActive" android:textIsSelectable="true" />

        <ImageView android:id="@+id/simpleview_imgDirection"
            android:layout_width="24dp" android:layout_height="24dp"
            android:layout_row="1" android:layout_column="2"
            android:layout_gravity="center"
            android:src="@drawable/direction"
            android:contentDescription="@string/txt_direction" />
        <TextView android:id="@+id/simpleview_txtDirection"
            android:layout_width="80dp" android:layout_height="wrap_content"
            android:layout_row="1" android:layout_column="3"
            android:layout_gravity="center_vertical"
            android:textColor="@color/navbarIconActive" android:textIsSelectable="true" />

        <ImageView android:id="@+id/simpleview_imgDuration"
            android:layout_width="24dp" android:layout_height="24dp"
            android:layout_row="2" android:layout_column="0"
            android:layout_gravity="center"
            android:src="@drawable/duration"
            android:contentDescription="@string/txt_travel_duration" />
        <TextView android:id="@+id/simpleview_txtDuration"
            android:layout_width="80dp" android:layout_height="wrap_content"
            android:layout_row="2" android:layout_column="1"
            android:layout_gravity="center_vertical"
            android:textColor="@color/navbarIconActive" android:textIsSelectable="true" />

        <ImageView android:id="@+id/simpleview_imgSpeed"
            android:layout_width="24dp" android:layout_height="24dp"
            android:layout_row="2" android:layout_column="2"
            android:layout_gravity="center"
            android:src="@drawable/speed"
            android:contentDescription="@string/txt_speed" />
        <TextView android:id="@+id/simpleview_txtSpeed"
            android:layout_width="80dp" android:layout_height="wrap_content"
            android:layout_row="2" android:layout_column="3"
            android:layout_gravity="center_vertical"
            android:textColor="@color/navbarIconActive" android:textIsSelectable="true" />

        <ImageView android:id="@+id/simpleview_distance"
            android:layout_width="24dp" android:layout_height="24dp"
            android:layout_row="3" android:layout_column="0"
            android:layout_gravity="center"
            android:src="@drawable/distance"
            android:contentDescription="@string/txt_travel_distance" />
        <TextView android:id="@+id/simpleview_txtDistance"
            android:layout_width="80dp" android:layout_height="wrap_content"
            android:layout_row="3" android:layout_column="1"
            android:layout_gravity="center_vertical"
            android:textColor="@color/navbarIconActive" android:textIsSelectable="true" />

        <ImageView android:id="@+id/simpleview_points"
            android:layout_width="24dp" android:layout_height="24dp"
            android:layout_row="3" android:layout_column="2"
            android:layout_gravity="center"
            android:src="@drawable/points"
            android:contentDescription="@string/txt_number_of_points" />
        <TextView android:id="@+id/simpleview_txtPoints"
            android:layout_width="80dp" android:layout_height="wrap_content"
            android:layout_row="3" android:layout_column="3"
            android:layout_gravity="center_vertical"
            android:textColor="@color/navbarIconActive" android:textIsSelectable="true" />

    </GridLayout>

    <!-- File type indicators -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        android:gravity="center">

        <ImageView android:id="@+id/simpleview_imgGpx"
            android:layout_width="25dp" android:layout_height="25dp"
            android:src="@drawable/gpx" android:paddingEnd="4dp"
            android:contentDescription="@string/log_gpx_title"
            android:visibility="invisible" />
        <ImageView android:id="@+id/simpleview_imgKml"
            android:layout_width="25dp" android:layout_height="25dp"
            android:src="@drawable/kml" android:paddingEnd="4dp"
            android:contentDescription="@string/log_kml_title"
            android:visibility="invisible" />
        <ImageView android:id="@+id/simpleview_imgCsv"
            android:layout_width="25dp" android:layout_height="25dp"
            android:src="@drawable/csv" android:paddingEnd="4dp"
            android:contentDescription="@string/log_plain_text_title"
            android:visibility="invisible" />
        <ImageView android:id="@+id/simpleview_imgNmea"
            android:layout_width="25dp" android:layout_height="25dp"
            android:src="@drawable/nmea" android:paddingEnd="4dp"
            android:contentDescription="@string/log_nmea_title"
            android:visibility="invisible" />
        <ImageView android:id="@+id/simpleview_imgjson"
            android:layout_width="25dp" android:layout_height="25dp"
            android:src="@drawable/geojson" android:paddingEnd="4dp"
            android:contentDescription="@string/log_json_title"
            android:visibility="invisible" />
        <ImageView android:id="@+id/simpleview_imgLink"
            android:layout_width="25dp" android:layout_height="25dp"
            android:src="@drawable/customurl"
            android:contentDescription="@string/log_customurl_title"
            android:visibility="invisible" />

    </LinearLayout>

    <!-- File path -->
    <TextView
        android:id="@+id/simpleview_txtfilepath"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:textColor="@color/navbarIconInactive"
        android:textSize="12sp" />

</LinearLayout>

</ScrollView>
